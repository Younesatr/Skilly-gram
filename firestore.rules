rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().role == 'user'
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && incoming().role == existing().role
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'username', 'bio', 'xp', 'level', 'streak', 'updatedAt'])
        && incoming().updatedAt == request.time;
    }

    // Post Rules
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && incoming().authorId == request.auth.uid
        && incoming().createdAt == request.time
        && isValidId(postId);
      allow update: if isSignedIn()
        && (
          (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaURLs', 'tags', 'updatedAt']))
          || (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'repostsCount']))
        );
      allow delete: if isOwner(existing().authorId);
    }

    // Community Rules
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(communityId);
      allow update: if isSignedIn();
    }

    // AI Recommendations (Private)
    match /ai_recommendations/{recId} {
      allow read, write: if isOwner(incoming().userId || existing().userId);
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Add recruiter role check later
    }
  }
}
